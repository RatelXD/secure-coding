# Local Compose development values. Replace every credential outside local development.
APP_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=development-only-change-me-before-any-shared-deployment-000000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TRUST_PROXY_HEADERS=false
POSTGRES_DB=marketplace
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=development-only-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
REDIS_URL=redis://redis:6379/0
